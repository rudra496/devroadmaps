{
  "id": "game-dev",
  "title": "Game Developer",
  "description": "Create interactive games from concept to publication. Learn game engines, programming, 2D/3D graphics, physics, audio, and how to publish and monetize your games.",
  "icon": "🎮",
  "color": "#f97316",
  "time": "8-14 months",
  "difficulty": "Beginner to Advanced",
  "nodes": [
    {"id":"gd-engine","title":"Choose a Game Engine","icon":"🎮","category":"fundamentals","description":"Unity (C#), Godot (GDScript/C#), Unreal (C++), or Phaser (JS) — pick based on your goals.","resources":[{"title":"Unity Learn (Free)","url":"https://learn.unity.com/","type":"course","free":true},{"title":"Godot Documentation","url":"https://docs.godotengine.org/","type":"docs","free":true},{"title":"Unreal Engine Learning","url":"https://dev.epicgames.com/community/unreal-engine/learning","type":"course","free":true}],"children":["gd-lang"]},
    {"id":"gd-lang","title":"Programming for Games","icon":"💻","category":"fundamentals","description":"C# for Unity, GDScript for Godot, C++ for Unreal, or JavaScript for web games — game loops, state machines, and OOP.","resources":[{"title":"C# Documentation","url":"https://learn.microsoft.com/en-us/dotnet/csharp/","type":"docs","free":true},{"title":"GDScript Basics","url":"https://docs.godotengine.org/en/stable/getting_started/first_script.html","type":"docs","free":true}],"children":["gd-math"]},
    {"id":"gd-math","title":"Game Math & Physics","icon":"🔢","category":"fundamentals","description":"Vectors, matrices, quaternions, collision detection, and physics simulations.","resources":[{"title":"3Blue1Brown Linear Algebra","url":"https://www.youtube.com/playlist?list=PLZHQObOWTQDPD3MizzM2xVFitgF8hE_ab","type":"video","free":true},{"title":"Game Math (Catlike Coding)","url":"https://catlikecoding.com/unity/tutorials/","type":"docs","free":true}],"children":["gd-2d"]},
    {"id":"gd-2d","title":"2D Game Development","icon":"🖼️","category":"frameworks","description":"Sprites, tilemaps, 2D physics, cameras, parallax scrolling, and 2D animation.","resources":[{"title":"Unity 2D Game Kit","url":"https://learn.unity.com/project/2d-game-kit","type":"course","free":true},{"title":"Godot 2D Docs","url":"https://docs.godotengine.org/en/stable/getting_started/first_2d_game/index.html","type":"docs","free":true}],"children":["gd-3d"]},
    {"id":"gd-3d","title":"3D Game Development","icon":"🌐","category":"frameworks","description":"3D meshes, materials, lighting, cameras, terrain, and 3D rendering pipelines.","resources":[{"title":"Unity 3D Tutorials","url":"https://learn.unity.com/","type":"course","free":true},{"title":"Godot 3D Docs","url":"https://docs.godotengine.org/en/stable/getting_started/first_3d_game/index.html","type":"docs","free":true}],"children":["gd-physics"]},
    {"id":"gd-physics","title":"Physics Engine","icon":"⚡","category":"frameworks","description":"Rigid bodies, colliders, triggers, raycasting, joints, and physics materials.","resources":[{"title":"Unity Physics","url":"https://docs.unity3d.com/Manual/PhysicsSection.html","type":"docs","free":true},{"title":"Godot Physics","url":"https://docs.godotengine.org/en/stable/tutorials/physics/physics_introduction.html","type":"docs","free":true}],"children":["gd-animation"]},
    {"id":"gd-animation","title":"Animation Systems","icon":"🏃","category":"frameworks","description":"Sprite animation, skeletal animation, animation state machines, blend trees, and IK.","resources":[{"title":"Unity Animation","url":"https://docs.unity3d.com/Manual/AnimationSection.html","type":"docs","free":true},{"title":"Godot Animation","url":"https://docs.godotengine.org/en/stable/tutorials/animation/animation_tree.html","type":"docs","free":true}],"children":["gd-audio"]},
    {"id":"gd-audio","title":"Audio & Sound Design","icon":"🔊","category":"tools","description":"Sound effects, background music, spatial audio, audio mixing, and FMOD/Wwise integration.","resources":[{"title":"FMOD Studio","url":"https://www.fmod.com/","type":"docs","free":true},{"title":"Free Sound Effects","url":"https://freesound.org/","type":"docs","free":true}],"children":["gd-ui"]},
    {"id":"gd-ui","title":"Game UI/UX","icon":"🖥️","category":"design","description":"Menus, HUD, health bars, inventory UI, and in-game interfaces.","resources":[{"title":"Unity UI Toolkit","url":"https://docs.unity3d.com/Manual/UIElements.html","type":"docs","free":true},{"title":"Godot UI System","url":"https://docs.godotengine.org/en/stable/tutorials/ui/gui_containers.html","type":"docs","free":true}],"children":["gd-ai"]},
    {"id":"gd-ai","title":"Game AI","icon":"🤖","category":"advanced","description":"Pathfinding (A*), behavior trees, finite state machines, and NPC AI patterns.","resources":[{"title":"A* Pathfinding Project","url":"https://arongranberg.com/astar/","type":"docs","free":true},{"title":"Game AI Programming (YouTube)","url":"https://www.youtube.com/results?search_query=game+ai+programming+tutorial","type":"video","free":true}],"children":["gd-multiplayer"]},
    {"id":"gd-multiplayer","title":"Multiplayer & Networking","icon":"🌐","category":"advanced","description":"Client-server architecture, netcode, latency compensation, and networking solutions (Mirror, FishNet, Photon).","resources":[{"title":"Mirror (Unity Networking)","url":"https://mirror-networking.com/","type":"docs","free":true},{"title":"Godot Multiplayer","url":"https://docs.godotengine.org/en/stable/tutorials/networking/high_level_multiplayer.html","type":"docs","free":true}],"children":["gd-optimization"]},
    {"id":"gd-optimization","title":"Performance Optimization","icon":"⚡","category":"advanced","description":"Profiling, object pooling, LOD, occlusion culling, and draw call optimization.","resources":[{"title":"Unity Performance","url":"https://docs.unity3d.com/Manual/Profiling.html","type":"docs","free":true},{"title":"Godot Performance","url":"https://docs.godotengine.org/en/stable/tutorials/performance/index.html","type":"docs","free":true}],"children":["gd-testing"]},
    {"id":"gd-testing","title":"Game Testing & QA","icon":"🧪","category":"testing","description":"Playtesting, unit testing game logic, automated testing, and bug tracking.","resources":[{"title":"Unity Test Framework","url":"https://docs.unity3d.com/Packages/com.unity.test-framework@1.1/manual/index.html","type":"docs","free":true}],"children":["gd-build"]},
    {"id":"gd-build","title":"Build & Distribution","icon":"🔨","category":"deployment","description":"Build for multiple platforms — PC, Mac, Linux, WebGL, mobile, and console.","resources":[{"title":"Unity Platform Setup","url":"https://docs.unity3d.com/Manual/PlatformSpecific.html","type":"docs","free":true}],"children":["gd-publish"]},
    {"id":"gd-publish","title":"Publishing & Stores","icon":"🏪","category":"deployment","description":"Steam, Itch.io, Epic Games Store, App Store, Google Play — store pages, requirements, and submission.","resources":[{"title":"Steamworks Documentation","url":"https://partner.steamgames.com/doc/sdk","type":"docs","free":true},{"title":"Itch.io for Developers","url":"https://itch.io/developers","type":"docs","free":true}],"children":["gd-monetize"]},
    {"id":"gd-monetize","title":"Monetization","icon":"💰","category":"advanced","description":"In-app purchases, ads, premium models, DLC, and business models for indie games.","resources":[{"title":"Unity IAP","url":"https://docs.unity3d.com/Manual/UnityIAP.html","type":"docs","free":true}],"children":[]},
    {"id":"gd-shaders","title":"Shader Programming","icon":"🎨","category":"advanced","description":"HLSL/GLSL shaders, Shader Graph, post-processing effects, and visual effects.","resources":[{"title":"Shader Tutorial (Catlike Coding)","url":"https://catlikecoding.com/unity/tutorials/custom-srp/","type":"docs","free":true},{"title":"The Book of Shaders","url":"https://thebookofshaders.com/","type":"docs","free":true}],"children":["gd-optimization"]},
    {"id":"gd-vcs","title":"Version Control for Games","icon":"🔀","category":"tools","description":"Git LFS for large files, asset versioning, and team collaboration workflows.","resources":[{"title":"Git LFS Documentation","url":"https://git-lfs.github.com/","type":"docs","free":true},{"title":"Unity Version Control","url":"https://unity.com/products/unity-version-control","type":"docs","free":true}],"children":["gd-multiplayer"]},
    {"id":"gd-design","title":"Game Design Principles","icon":"📋","category":"design","description":"Game loops, mechanics, level design, difficulty curves, player psychology, and prototyping.","resources":[{"title":"Game Design Workshop (YouTube)","url":"https://www.youtube.com/results?search_query=game+design+principles","type":"video","free":true},{"title":"Game Design Document Template","url":"https://www.gamedeveloper.com/design/how-to-write-a-game-design-document","type":"docs","free":true}],"children":["gd-2d"]},
    {"id":"gd-procedural","title":"Procedural Generation","icon":"🎲","category":"advanced","description":"Procedural terrain, dungeon generation, noise functions (Perlin/Simplex), and infinite worlds.","resources":[{"title":"Procedural Generation Wiki","url":"https://pcg.wikidot.com/","type":"docs","free":true}],"children":["gd-3d"]},
    {"id":"gd-particles","title":"Particle Systems & VFX","icon":"✨","category":"advanced","description":"Particle effects, trails, explosions, weather effects, and visual polish.","resources":[{"title":"Unity VFX Graph","url":"https://docs.unity3d.com/Packages/com.unity.visualeffectgraph@latest","type":"docs","free":true},{"title":"Godot GPUParticles","url":"https://docs.godotengine.org/en/stable/classes/class_gpuparticles2d.html","type":"docs","free":true}],"children":["gd-optimization"]},
    {"id":"gd-web","title":"Web Games (HTML5)","icon":"🌐","category":"frameworks","description":"Phaser, Three.js, or Godot WebGL export — build games that run in the browser.","resources":[{"title":"Phaser Documentation","url":"https://phaser.io/docs/","type":"docs","free":true},{"title":"Three.js Documentation","url":"https://threejs.org/docs/","type":"docs","free":true}],"children":["gd-build"]}
  ],
